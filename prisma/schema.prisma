// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages        Message[]
  threads         Thread[]
  memberships     WorkspaceMember[]

  // DM relations
  conversations   ConversationParticipant[]
  directMessages  DirectMessage[]
}

model Workspace {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())

  sections  Section[]
  members   WorkspaceMember[]
}

model WorkspaceMember {
  id          String  @id @default(uuid())
  userId      String
  workspaceId String
  role        String?

  user      User      @relation(fields: [userId], references: [id])
  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@unique([userId, workspaceId])
}

model Section {
  id          String @id @default(uuid())
  name        String
  workspaceId String

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  threads   Thread[]
}

model Thread {
  id          String   @id @default(uuid())
  title       String
  sectionId   String
  createdById String
  createdAt   DateTime @default(now())

  section   Section   @relation(fields: [sectionId], references: [id])
  createdBy User      @relation(fields: [createdById], references: [id])
  messages  Message[]
}

model Message {
  id        String   @id @default(uuid())
  content   String
  threadId  String
  userId    String
  createdAt DateTime @default(now())

  thread Thread @relation(fields: [threadId], references: [id])
  user   User   @relation(fields: [userId], references: [id])
}

// ─── Direct Messaging ───────────────────────────────────────────────────────

// A Conversation is a unique 1-to-1 channel between two users.
model Conversation {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt // bumped on every new message — use for sorting

  participants   ConversationParticipant[]
  directMessages DirectMessage[]
}

// Join table: one row per user per conversation (always exactly 2 rows per Conversation)
model ConversationParticipant {
  id             String @id @default(uuid())
  conversationId String
  userId         String

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id])

  @@unique([conversationId, userId]) // prevent duplicate participants
  @@index([userId])                  // fast: "all conversations for user X"
}

model DirectMessage {
  id             String    @id @default(uuid())
  content        String
  conversationId String
  senderId       String
  createdAt      DateTime  @default(now())
  editedAt       DateTime? // null until edited
  deleted        Boolean   @default(false) // soft delete — keep history intact

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id])

  @@index([conversationId, createdAt]) // fast paginated fetch newest-first
}
  